# Copy this file to .env for local development and replace placeholders.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/explore_app
SPRING_DATASOURCE_USERNAME=replace-with-local-db-user
SPRING_DATASOURCE_PASSWORD=replace-with-local-db-password

# Must be at least 32 bytes.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_MS=86400000

# Optional local CORS override. Omit to use the built-in localhost defaults.
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000

# Optional rate-limit overrides.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW=PT1M
RATE_LIMIT_REGISTER_MAX_REQUESTS=5
RATE_LIMIT_REGISTER_WINDOW=PT15M
RATE_LIMIT_DISCOVERY_MAX_REQUESTS=120
RATE_LIMIT_DISCOVERY_WINDOW=PT1M
RATE_LIMIT_ADMIN_IMAGE_UPLOAD_MAX_REQUESTS=20
RATE_LIMIT_ADMIN_IMAGE_UPLOAD_WINDOW=PT10M

# Optional unless backend-managed Firebase Storage uploads are enabled.
FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
FIREBASE_LOCATION_IMAGE_STORAGE_ROOT=locations
FIREBASE_SERVICE_ACCOUNT_PATH=replace-with-local-service-account-path
# FIREBASE_SERVICE_ACCOUNT_BASE64=replace-with-base64-encoded-service-account-json
