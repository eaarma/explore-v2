{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.explore.tourhub.space",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    },
    "internal-production": {
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.explore.tourhub.space",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.explore.tourhub.space",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      }
    }
  }
}
