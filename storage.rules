rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This app uploads location images through the backend Admin SDK only.
    // Deny all direct client SDK reads and writes by default.
    match /locations/{locationId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
